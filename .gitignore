# ──────────────────────────────────────────────────────────────────────────────
# SCARA Pick-and-Place Robot — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.coveragerc
.tox/

# ── Type checkers ─────────────────────────────────────────────────────────────
.mypy_cache/
.pytype/
.pyre/

# ── Jupyter Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Matplotlib output / saved figures ─────────────────────────────────────────
*.png
*.jpg
*.jpeg
*.svg
*.pdf
*.eps
plots/
figures/
output/

# ── IDE & editor files ────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Hardware / MCU build artefacts (Phase 2+) ─────────────────────────────────
*.hex
*.bin
*.elf
*.map
*.lst
*.o
*.a
firmware/build/

# ── Logs & data dumps ─────────────────────────────────────────────────────────
*.log
*.csv
*.dat
logs/
data/raw/

# ── Secrets & local config overrides ─────────────────────────────────────────
.env.local
secrets.yaml
local_config.yaml

# ── Keep these tracked (override any broad rules above) ───────────────────────
!config/robot_params.yaml
!config/pid_params.yaml
!config/vision_params.yaml
!requirements.txt
!README.md
